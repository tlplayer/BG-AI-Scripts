LAF SIIS_ADD_SUNDRIES_ITEM STR_VAR item = ~OHNROBE3~ END
LAF SIIS_ADD_SUNDRIES_ITEM INT_VAR charge1 = 50 STR_VAR item = ~OHNWAND1~ END

// Dorn: compact Blackguard-path gear selection.
LAF SIIS_ADD_SUNDRIES_ITEM STR_VAR item = ~OHDARMOR~ END
